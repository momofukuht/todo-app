[project]
name = "Todo App"
description = "Vue.js + Laravel + MariaDB のTodoアプリケーション"
type = "fullstack"

[structure]
root = "."

[frontend]
path = "frontend"
framework = "vue"
port = 5173
description = "Vue.jsフロントエンドアプリケーション"

[backend]
path = "backend"
framework = "laravel"
port = 8000
description = "Laravel APIバックエンド"

[database]
type = "mariadb"
port = 3306

[docker]
compose_file = "docker-compose.yml"
services = ["frontend", "backend", "db"]

[[relations]]
from = "frontend/src/services/api.js"
to = "backend/routes/api.php"
description = "フロントエンドからバックエンドAPIを呼び出す"

[[relations]]
from = "backend/app/Models/Todo.php"
to = "backend/database/migrations/2024_01_01_000000_create_todos_table.php"
description = "Todoモデルとマイグレーションの対応"

[[relations]]
from = "backend/routes/api.php"
to = "backend/app/Http/Controllers/TodoController.php"
description = "APIルートとコントローラーの対応"
